{
  "name": "TarchPeek",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "api:generate": "orval --config ./orval.config.js",
    "start": "react-native start",
    "e2e:build:android": "cd android && ./gradlew assembleMaestro && cd ..",
    "e2e:verify:emulator-network": "node scripts/verify-emulator-ta-network.mjs",
    "e2e:test:android": "node scripts/run-maestro-android.mjs maestro",
    "ta:seed:bootstrap": "node scripts/tubearchivist-manager.mjs bootstrap-seed",
    "ta:seed:capture": "node scripts/tubearchivist-manager.mjs capture-seed",
    "ta:seed:reset-start": "node scripts/tubearchivist-manager.mjs reset-and-start",
    "ta:seed:stop": "node scripts/tubearchivist-manager.mjs stop"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "3.0.2",
    "@react-navigation/bottom-tabs": "^7.15.11",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.12",
    "@shopify/flash-list": "^2.3.1",
    "axios": "1.16.0",
    "react": "19.2.3",
    "react-native": "0.85.2",
    "react-native-gesture-handler": "^2.31.1",
    "react-native-nitro-modules": "^0.35.5",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-screens": "^4.24.0",
    "react-native-vector-icons": "^10.3.0",
    "react-native-video": "^7.0.0-beta.9"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.3",
    "@react-native-community/cli-platform-android": "20.1.3",
    "@react-native-community/cli-platform-ios": "20.1.3",
    "@react-native/babel-preset": "0.85.2",
    "@react-native/eslint-config": "0.85.2",
    "@react-native/metro-config": "0.85.2",
    "@react-native/typescript-config": "0.85.2",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.0",
    "@types/react-native-vector-icons": "^6.4.18",
    "eslint": "^8.19.0",
    "eslint-plugin-deprecation": "^3.0.0",
    "jest": "^30.2.0",
    "orval": "^8.9.0",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">= 22.11.0"
  }
}
